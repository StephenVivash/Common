<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WattCycleApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:WattCycleApp.Pages"
    FlyoutBehavior="Disabled">

	<FlyoutItem Route="Battery">
		<ShellContent
			x:Name="pagBattery"
			Shell.NavBarIsVisible="false"
			ContentTemplate="{DataTemplate pages:BatteryPage}"
			Route="BatteryRoot" />
	</FlyoutItem>

	<FlyoutItem Route="Graph">
		<ShellContent
			x:Name="pagGraph"
			Shell.NavBarIsVisible="false"
			ContentTemplate="{DataTemplate pages:GraphPage}"
			Route="GraphRoot" />
	</FlyoutItem>
</Shell>
