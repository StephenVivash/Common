<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WattCycleApp.MainPage"
             >
    <Grid Padding="12"
          RowDefinitions="Auto,*"
          RowSpacing="10">
        <Grid ColumnDefinitions="*,*,*,*"
              ColumnSpacing="8"
              RowDefinitions="Auto,Auto">
            <Label Grid.Column="0" Text="Batteries" HorizontalTextAlignment="Center" FontSize="12" />
            <Label Grid.Column="1" Text="Scan" HorizontalTextAlignment="Center" FontSize="12" />
            <Label Grid.Column="2" Text="Loop" HorizontalTextAlignment="Center" FontSize="12" />
            <Label Grid.Column="3" Text="Timeout" HorizontalTextAlignment="Center" FontSize="12" />

            <Entry x:Name="BatteriesEntry"
                   Grid.Row="1"
                   Text="4"
                   Keyboard="Numeric"
                   HorizontalTextAlignment="Center" />
            <Entry x:Name="ScanEntry"
                   Grid.Row="1"
                   Grid.Column="1"
                   Text="2"
                   Keyboard="Numeric"
                   HorizontalTextAlignment="Center" />
            <Entry x:Name="LoopEntry"
                   Grid.Row="1"
                   Grid.Column="2"
                   Text="5"
                   Keyboard="Numeric"
                   HorizontalTextAlignment="Center" />
            <Entry x:Name="TimeoutEntry"
                   Grid.Row="1"
                   Grid.Column="3"
                   Text="30"
                   Keyboard="Numeric"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Batteries}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{AppThemeBinding Light=#D0D0D0, Dark=#505050}"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="3">
                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1"
                                   Text="{Binding StateOfChargeText}"
                                   TextColor="{Binding StateOfChargeColor}"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   HorizontalTextAlignment="End" />

                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,*,*,*,*"
                                  ColumnSpacing="1">
                                <Label Text="{Binding VoltageText}"
                                       TextColor="{Binding VoltageColor}"
                                       FontSize="14" />
                                <Label Grid.Column="1"
                                       Text="{Binding CurrentText}"
                                       TextColor="{Binding CurrentColor}"
                                       FontSize="14" />
                                <Label Grid.Column="2"
                                       Text="{Binding PowerText}"
                                       TextColor="{Binding PowerColor}"
                                       FontSize="14" />
                                <Label Grid.Column="3"
                                       Text="Cha"
                                       TextColor="{Binding ChargeTextColor}"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center" />
                                <Label Grid.Column="4"
                                       Text="Dis"
                                       TextColor="{Binding DischargeTextColor}"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center" />
                            </Grid>

                            <Label Grid.Row="2"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding Status}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#606060, Dark=#B0B0B0}"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
